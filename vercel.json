{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/", "dest": "public/login/index.html" },
    { "src": "/login", "dest": "public/login/index.html" },
    { "src": "/login/", "dest": "public/login/index.html" },
    { "src": "/signup", "dest": "public/signup/index.html" },
    { "src": "/signup/", "dest": "public/signup/index.html" },
    { "src": "/home", "dest": "public/home/index.html" },
    { "src": "/home/", "dest": "public/home/index.html" },
    { "src": "/study", "dest": "public/study/index.html" },
    { "src": "/study/", "dest": "public/study/index.html" },
    { "src": "/exam", "dest": "public/exam/index.html" },
    { "src": "/exam/", "dest": "public/exam/index.html" },
    { "src": "/exam/mobile", "dest": "public/exam/mobile.html" },
    { "src": "/exam/mobile/", "dest": "public/exam/mobile.html" },
    { "src": "/admin", "dest": "public/admin/index.html" },
    { "src": "/admin/", "dest": "public/admin/index.html" },
    { "src": "/curriculum-info", "dest": "public/curriculum-info/index.html" },
    { "src": "/curriculum-info/", "dest": "public/curriculum-info/index.html" },
    { "src": "/streak", "dest": "public/streak/index.html" },
    { "src": "/streak/", "dest": "public/streak/index.html" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
